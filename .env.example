# ==========================================
# Mana Warangal Foods Environment Variables Configuration
# Copy this file to `.env.production` or `.env.local` and populate values
# ==========================================

# Firebase Web App SDK configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Google Maps API Key for Rider & Customer live tracking mapping
# Recommended restriction: restrict API key to HTTP Referrers of your production domain (e.g. *.web.app)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Razorpay Checkout API Key ID for online payment integration
# Recommended restriction: use test key for staging (`rzp_test_...`) or live key (`rzp_live_...`) for production
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here

# Supabase Configuration (Project: CaptainBro)
# Database Password: vHn4ZQ@YGkCuKXV
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

